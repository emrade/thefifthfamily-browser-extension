{
  "manifest_version": 3,
  "name": "The Fifth Family Enhancements",
  "version": "0.1.0",
  "description": "Companion tools for The Fifth Family",
  "permissions": [
    "alarms",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://www.thefifthfamily.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "scripts": ["src/background/index.ts"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.thefifthfamily.com/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.thefifthfamily.com/*"],
      "js": ["src/content/mainWorldHook.ts"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "The Fifth Family Enhancements"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "thefifthfamily-enhancements@extension",
      "strict_min_version": "128.0"
    }
  }
}
